design <- data.frame(focal_sp=NA, focal_n=NA, combo_id=NA, combo=NA, sp_n=NA, nA=NA, nB=NA, nC=NA, nD=NA, nE=NA, nF=NA, temp=NA, rep=NA)
for (r in 1:length(reps)){
for(t in 1:length(temps)) {
curr_temp = temps[t]
for (i in 1:length(combos)){
curr_sp_list <- combos[[i]]
n_sp <- length(curr_sp_list)
n_parents <- case_when(n_sp == 1 ~ 6, n_sp == 2 ~ 3, n_sp == 3 ~ 2, n_sp == 6 ~ 1)
for (sp in 1:length(curr_sp_list)){
t_focal <- curr_sp_list[sp]
t_focal_n <- n_parents
t_combo_id <- i
t_combo <- result_clean <- paste0(curr_sp_list, collapse = "")
t_sp_n <- length(curr_sp_list)
t_nA <- ifelse("A" %in% curr_sp_list, n_parents, 0)
t_nB <- ifelse("B" %in% curr_sp_list, n_parents, 0)
t_nC <- ifelse("C" %in% curr_sp_list, n_parents, 0)
t_nD <- ifelse("D" %in% curr_sp_list, n_parents, 0)
t_nE <- ifelse("E" %in% curr_sp_list, n_parents, 0)
t_nF <- ifelse("F" %in% curr_sp_list, n_parents, 0)
t_temp <- curr_temp
t_rep <- r
t_entry <- cbind(focal_sp=t_focal, focal_n=n_parents, combo_id=t_combo_id, combo=t_combo, sp_n=t_sp_n,
nA=t_nA, nB=t_nB, nC=t_nC, nD=t_nD, nE=t_nE, nF=t_nF,
temp=t_temp, rep=t_rep)
design <- rbind(design, t_entry)
}
}
}
}
design <- design[-1,]
design <- design %>% mutate(combo_id = as.numeric(combo_id), focal_n=as.numeric(focal_n), sp_n=as.numeric(sp_n),
nA=as.numeric(nA), nB=as.numeric(nB), nC=as.numeric(nC),
nD=as.numeric(nD), nE=as.numeric(nE), nF=as.numeric(nF), offspring = NA)
# --- 6. Run Simulation ---
for (t in 1:length(design$focal_sp)) {
# generate expected offspring number of the focal species for each entry
curr_sp <- design$focal_sp[t]
r_i <- r_matrix[r_matrix$species == curr_sp, design$temp[t]]
curr_beta_mat <- beta_mat
# modify the competition coefficient matrix due to temperature
if(temp == "Mid"){
for (ct in 1:length(compXtemp_rules)){
curr_beta_mat[compXtemp_rules$i[ct],compXtemp_rules$j[ct]] <- curr_beta_mat[compXtemp_rules$i[ct],compXtemp_rules$j[ct]] + compXtemp_rules$effect[ct] # at Mid temperature, the competition effect is getting higher
}
}
# modify the competition coefficient matrix due to HOI
if(design$sp_n[t] >= 3){ # no HOI if sp<3
for (h in 1:length(hoi_rules$combo)) { # check if any of the HOI sp combo is part of the current combo
if(all(strsplit(hoi_rules$combo[h], "")[[1]] %in% strsplit(design$combo[t], "")[[1]])){ # if HOI combo is part of the current combo
hoi <- hoi_rules[h,]
curr_beta_mat[as.numeric(hoi$i_id), as.numeric(hoi$j_id)] <- curr_beta_mat[as.numeric(hoi$i_id), as.numeric(hoi$j_id)] + as.numeric(hoi$effect)
}
}
}
# calculate focal species' offspring number
focal_id <- case_when(curr_sp == "A" ~ 1, curr_sp == "B" ~ 2, curr_sp == "C" ~ 3, curr_sp == "D" ~ 4, curr_sp == "E" ~ 5, curr_sp == "F" ~ 6)
dinominator <- 1+curr_beta_mat[focal_id,1]*design$nA[t]+curr_beta_mat[focal_id,2]*design$nB[t]+curr_beta_mat[focal_id,3]*design$nC[t]+curr_beta_mat[focal_id,4]*design$nD[t]+curr_beta_mat[focal_id,5]*design$nE[t]+curr_beta_mat[focal_id,6]*design$nF[t]
expected_n <- design$focal_n[t]*r_i/dinominator # expected mean of offspring number
design$offspring[t] <- rpois(1, lambda = expected_n) # random draw from a poisson distribution
}
design <- design %>% mutate(combo_id = as.numeric(combo_id), focal_n=as.numeric(focal_n), sp_n=as.numeric(sp_n),
nA=as.numeric(nA), nB=as.numeric(nB), nC=as.numeric(nC),
nD=as.numeric(nD), nE=as.numeric(nE), nF=as.numeric(nF), offspring = NA)
#design <- expand.grid(combo_id = 1:length(combos), temp = temps, rep = reps)
